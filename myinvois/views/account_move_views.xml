<odoo>

    <record id="myinvois_invoice_form_view" model="ir.ui.view">
        <field name="name">pc.myinvois.invoice.form.view</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <field name="myinvois_document_id" invisible="1"/>
                <button name="cancel_myinvois_doc" type="object" string="Cancel Document" class="btn btn-secondary" attrs="{'invisible': ['|',('state', 'in', ['draft', 'cancel']),('myinvois_document_id', '=', False)]}"/>
                <button name="action_get_document_details" type="object" string="Check MyInvois Status" class="btn btn-secondary" attrs="{'invisible': [('my_invois_uuid', '=', False)]}"/>
                <button name="submit_document_action" type="object" string="Submit Document" class="btn btn-secondary" attrs="{'invisible': ['|',('state', '!=', 'posted'), ('my_invois_uuid', '!=', False)]}"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page name="my_invois" string="MyInvois" attrs="{'invisible': [('my_invois_access_token', '=', False)]}">
                    <group id="myinvois_info">
                        <group>
                            <field name="my_invois_version" readonly="1"/>
                            <field name="my_invois_access_token" invisible="1"/> 
                            <field name="my_invois_uuid" readonly="1"/> 
                            <field name="myinvois_document_id" readonly="1"/> 
                            <field name="my_invois_id_submission" readonly="1"/> 
                            <field name="my_invois_status_submission" readonly="1"/>
                            <field name="my_invois_cancel_reason" attrs="{'invisible': [('my_invois_status_submission', '!=', 'Cancelled')]}"/>   
                            <field name="my_invois_cancelled_date" attrs="{'invisible': [('my_invois_status_submission', '!=', 'Cancelled')]}"/>
    
                        </group>
                        <group>
                            <!-- <field name="my_invois_period_id" /> -->
                            <field name="myinvois_consolidate_id" readonly="1"/>
                            <field name="my_invois_einvoice_type_id" readonly="1"/>
                            <field name="my_invois_qr_code" widget='image'/>
                        </group>
                        
                    </group>
                    <!-- <group>
                        <field name="my_invois_additional_doc_ids">
                            <tree editable="bottom">
                                <field name="name" />
                                <field name="document_type" />
                            </tree>
                        </field>      
                    </group> -->
                </page>
            </xpath>
            <!-- <xpath expr="//field[@name='invoice_line_ids']//tree//field[@name='tax_ids']" position="after">
                <field name="tax_type_id" required="1"/>
            </xpath> -->
            <xpath expr="//group[@name='sale_info_group']" position="inside">
                <field name="my_invois_rejection" attrs="{'invisible': [('my_invois_access_token', '=', False)]}"/>
                <field name="my_invois_rejection_date" attrs="{'invisible': [('my_invois_access_token', '=', False)]}"/> 
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='product_id']" position="after">
                <field name="myinvois_product_classification_code" optional="show"/>
            </xpath>

        </field>
    </record>

    <record id="my_invois_view_account_invoice_filter" model="ir.ui.view">
        <field name="name">my.invois.view.account.invoice.filter</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/filter[@name='cancel']" position="after">
                <filter string="Reject Requested" name="my_invois_rejection" domain="[('my_invois_rejection', '=', True)]"/>
                <filter string="Submitted to MyInvois" name="my_invois_submitted" domain="[('my_invois_uuid', '!=', False)]"/>
            </xpath>
        </field>
    </record>

    <record id="my_invois_view_account_move_myinvois" model="ir.ui.view">
        <field name="name">my.invois.view.account.move.myinvois</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="my_invois_status_submission"/>
            </field>
        </field>
    </record>


</odoo>
