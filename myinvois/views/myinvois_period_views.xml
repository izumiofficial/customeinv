<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_view_myinvois_period" model="ir.actions.act_window">
        <field name="name">MyInvois Period</field>
        <field name="res_model">myinvois.period</field>
        <field name="view_mode">tree,form</field>
    </record>
    
    <menuitem id="menu_myinvois_period" name="MyInvois Period" parent="pc_myinvois.menu_myinvois" sequence="5" action="action_view_myinvois_period"/>

    <record id="myinvois_period_tree" model="ir.ui.view">
        <field name="name">myinvois.period.tree</field>
        <field name="model">myinvois.period</field>
        <field name="arch" type="xml">
            <tree string="MyInvois Period">
                <field name="my_invois_periode_description"/>
                <field name="my_invois_periode_start"/>
                <field name="my_invois_periode_end"/>
            </tree>
        </field>
    </record>

    <record id="myinvois_period_form" model="ir.ui.view">
        <field name="name">myinvois.period.form</field>
        <field name="model">myinvois.period</field>
        <field name="arch" type="xml">
            <form string="MyInvois Period">
                <group>
                    <group>
                        <field name="my_invois_periode_description"/>
                        <field name="my_invois_periode_start" string="Invois Period" widget="daterange" options="{'related_end_date': 'my_invois_periode_end'}" />
                        <field name="my_invois_periode_end" invisible="1"/>
                    </group>
                </group>
            </form>
        </field>
    </record>
</odoo>