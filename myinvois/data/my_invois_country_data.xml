<odoo>
    <record id="sync_my_invois_country_code_action" model="ir.cron">
        <field name="name">Sync MY INVOIS Country Code</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="model_id" ref="base.model_res_country"/>
        <field name="code">model.sync_my_invois_country()</field>
        <field name="active" eval="False"/>
        <field name="doall" eval="True"/>
        <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 02:00:00')" />
    </record>
</odoo>